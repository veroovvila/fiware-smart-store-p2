# FIWARE Smart Store - Environment Variables Template
# Copy this file to .env and update values for your local development

# === MONGODB ===
MONGO_PORT=27017
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=root
MONGO_DB=fiware_smartstore

# === FLASK BACKEND ===
FLASK_PORT=5000
FLASK_ENV=development
FLASK_APP=app.py

# === ORION CONTEXT BROKER ===
ORION_PORT=1026
ORION_URL=http://localhost:1026

# === FRONTEND ===
FRONTEND_PORT=8080

# === EXTERNAL APIs ===
# Weather API (Temperature, Humidity)
WEATHER_API_URL=http://weather-api:8080
WEATHER_API_KEY=your_weather_api_key

# Twitter API (Tweets/Sentiment)
TWITTER_API_URL=http://twitter-api:8080
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# === LOGGING ===
LOG_LEVEL=INFO

# === SECURITY ===
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_key_here
